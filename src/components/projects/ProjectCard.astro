---
interface Props {
	title: string;
	tagline: string;
	status: "active" | "beta" | "development" | "archived";
	id: string;
	thumbnail?: string | undefined;
	category: string;
}

const { title, tagline, status, id, thumbnail, category } = Astro.props;

const statusConfig = {
	active: { label: "公開中", className: "bg-status-active" },
	beta: { label: "Beta", className: "bg-status-beta" },
	development: { label: "開発中", className: "bg-status-development" },
	archived: { label: "終了", className: "bg-status-archived" },
} as const;

const { label: statusLabel, className: statusClassName } = statusConfig[status];
---

<a
  href={`/projects/${id}`}
  class="group block bg-bg-card border border-border rounded-lg overflow-hidden hover:border-brand transition-colors"
>
  {thumbnail ? (
    <img src={thumbnail} alt={title} class="w-full aspect-video object-cover" />
  ) : (
    <div class="w-full aspect-video bg-bg-muted flex items-center justify-center">
      <span class="text-text-muted text-xs font-medium tracking-widest uppercase">
        {category}
      </span>
    </div>
  )}
  <div class="p-5">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="font-semibold text-lg text-text-primary group-hover:text-text-brand transition-colors leading-tight">
        {title}
      </h3>
      <span class={`shrink-0 text-xs px-2 py-0.5 rounded-full font-medium text-white ${statusClassName}`}>
        {statusLabel}
      </span>
    </div>
    <p class="text-sm text-text-secondary leading-relaxed">
      {tagline}
    </p>
  </div>
</a>
